{
  "hooks": {
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "bash scripts/hooks/on-prompt.sh",
        "timeout": 15000
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "bash scripts/hooks/on-session-end.sh",
        "timeout": 120000
      }
    ]
  }
}
