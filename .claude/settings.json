{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "python3 scripts/hooks/bridge.py session-start",
        "timeout": 15000
      },
      {
        "type": "command",
        "command": "bash scripts/hooks/on-session-start.sh",
        "timeout": 15000
      },
      {
        "type": "command",
        "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh",
        "timeout": 300000
      }
    ],
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "python3 scripts/hooks/bridge.py user-query",
        "timeout": 15000
      },
      {
        "type": "command",
        "command": "bash scripts/hooks/on-prompt.sh",
        "timeout": 15000
      },
      {
        "type": "command",
        "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/query-counter.sh",
        "timeout": 60000
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(Bash|Edit|Write|NotebookEdit|MultiEdit|Read|Grep|Glob|Task)$",
        "type": "command",
        "command": "python3 scripts/hooks/bridge.py tool-call",
        "timeout": 30000
      },
      {
        "matcher": "^(Bash|Edit|Write|NotebookEdit|MultiEdit)$",
        "type": "command",
        "command": "bash scripts/hooks/on-code-change.sh",
        "timeout": 30000
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "python3 scripts/hooks/bridge.py session-end",
        "timeout": 30000
      },
      {
        "type": "command",
        "command": "bash scripts/hooks/on-session-end.sh",
        "timeout": 120000
      }
    ]
  }
}
